<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="9.0.11" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="9.0.11" PrivateAssets="all" />
    <PackageReference Include="MudBlazor" Version="8.6.0" />
    <PackageReference Include="Toolbelt.Blazor.HotKeys2" Version="6.2.0" />
  </ItemGroup>
  <ItemGroup>
    <Content Update="wwwroot/appsettings.Development.json">
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <_ContentIncludedByDefault Remove="publish\web.config" />
    <_ContentIncludedByDefault Remove="publish\AutoEmply_Client.staticwebassets.endpoints.json" />
    <_ContentIncludedByDefault Remove="publish\publish\AutoEmply_Client.staticwebassets.endpoints.json" />
    <_ContentIncludedByDefault Remove="publish\publish\segmentation-rules.json" />
    <_ContentIncludedByDefault Remove="publish\publish\wwwroot\appsettings.json" />
    <_ContentIncludedByDefault Remove="publish\publish\wwwroot\_framework\blazor.boot.json" />
    <_ContentIncludedByDefault Remove="publish\segmentation-rules.json" />
    <_ContentIncludedByDefault Remove="publish\wwwroot\appsettings.json" />
    <_ContentIncludedByDefault Remove="publish\wwwroot\_framework\blazor.boot.json" />
  </ItemGroup>

</Project>

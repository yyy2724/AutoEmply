@inherits LayoutComponentBase
@implements IDisposable
@inject Toolbelt.Blazor.HotKeys2.HotKeys HotKeys

<MudThemeProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">AutoEmply</MudText>
        <MudSpacer/>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/create">생성</MudButton>
        @if (_showPresetButton)
        {
            <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/presets">프리셋 관리</MudButton>
        }
        <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/home">홈</MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code{
    private Toolbelt.Blazor.HotKeys2.HotKeysContext? _hotKeys;
    private bool _showPresetButton;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
            return;

        _hotKeys = HotKeys.CreateContext()
            .Add(
                Toolbelt.Blazor.HotKeys2.ModCode.None,
                Toolbelt.Blazor.HotKeys2.Code.F1,
                TogglePresetButton,
                "Toggle Presets Button");
    }

    private void TogglePresetButton()
    {
        _showPresetButton = !_showPresetButton;
        StateHasChanged();
    }

    public void Dispose()
    {
        _hotKeys?.Dispose();
    }
}

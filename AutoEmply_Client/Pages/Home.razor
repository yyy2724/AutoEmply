@page "/home"
@implements IDisposable
@inject Toolbelt.Blazor.HotKeys2.HotKeys HotKeys

<PageTitle>홈</PageTitle>

<MudPaper Class="pa-6">
    <MudText Typo="Typo.h4" GutterBottom="true">AutoEmply 클라이언트</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">
        이미지/PDF를 분석해 Delphi QuickReport 파일을 만들고, 프롬프트를 DB에서 추적 관리할 수 있습니다.
    </MudText>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/create">생성 화면</MudButton>
        @if (_showPresetButton)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/presets">프리셋 관리 화면</MudButton>
        }
    </MudStack>
</MudPaper>

@code {
    private Toolbelt.Blazor.HotKeys2.HotKeysContext? _hotKeys;
    private bool _showPresetButton;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
            return;

        _hotKeys = HotKeys.CreateContext()
            .Add(
                Toolbelt.Blazor.HotKeys2.ModCode.None,
                Toolbelt.Blazor.HotKeys2.Code.F1,
                TogglePresetButton,
                "Toggle Presets Button");
    }

    private void TogglePresetButton()
    {
        _showPresetButton = !_showPresetButton;
        StateHasChanged();
    }

    public void Dispose()
    {
        _hotKeys?.Dispose();
    }
}
